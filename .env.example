# =========================================
# .env Dosyası - Docker Compose Ortam Değişkenleri
# =========================================
# Bu dosyayı kopyalayın ve değerleri güncelleyin:
# cp .env.example .env

# JWT Secret Key - Mutlaka güçlü bir değer girin!
JWT_SECRET=degistirmeniz-gereken-gizli-anahtar-en-az-32-karakter

# Node ortamı
NODE_ENV=production
